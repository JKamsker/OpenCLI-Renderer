{
  "info": {
    "title": "neotrace",
    "version": "3.9.1",
    "description": "neotrace generates debug trace files for existing blocks and/or transactions"
  },
  "options": [
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--help",
      "description": "Show help and usage information",
      "aliases": [
        "-h"
      ]
    }
  ],
  "commands": [
    {
      "name": "block",
      "description": "Trace all transactions in a specified block",
      "options": [
        {
          "name": "--rpc-uri",
          "description": "URL of Neo JSON-RPC Node\nSpecify MainNet (default), TestNet or JSON-RPC URL",
          "aliases": [
            "-r"
          ],
          "arguments": [
            {
              "name": "RPC_URI",
              "required": true,
              "type": "String",
              "arity": {
                "minimum": 1,
                "maximum": 1
              }
            }
          ]
        },
        {
          "name": "--help",
          "description": "Show help and usage information",
          "aliases": [
            "-h"
          ]
        }
      ],
      "arguments": [
        {
          "name": "BLOCKIDENTIFIER",
          "description": "Block index or hash",
          "required": true,
          "type": "String",
          "arity": {
            "minimum": 1,
            "maximum": 1
          }
        }
      ]
    },
    {
      "name": "transaction",
      "description": "Trace the specified transaction",
      "aliases": [
        "tx"
      ],
      "options": [
        {
          "name": "--rpc-uri",
          "description": "URL of Neo JSON-RPC Node\nSpecify MainNet (default), TestNet or JSON-RPC URL",
          "aliases": [
            "-r"
          ],
          "arguments": [
            {
              "name": "RPC_URI",
              "required": true,
              "type": "String",
              "arity": {
                "minimum": 1,
                "maximum": 1
              }
            }
          ]
        },
        {
          "name": "--help",
          "description": "Show help and usage information",
          "aliases": [
            "-h"
          ]
        }
      ],
      "arguments": [
        {
          "name": "TRANSACTIONHASH",
          "description": "Block index or hash",
          "required": true,
          "type": "String",
          "arity": {
            "minimum": 1,
            "maximum": 1
          }
        }
      ]
    }
  ]
}