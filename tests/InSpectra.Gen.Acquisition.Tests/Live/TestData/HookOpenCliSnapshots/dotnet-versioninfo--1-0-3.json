{
  "info": {
    "title": "versioninfo",
    "version": "1.0.3",
    "description": "Display version information of .NET Core assemblies"
  },
  "options": [
    {
      "name": "--relative",
      "description": "Show relative paths in the results",
      "aliases": [
        "-r"
      ]
    },
    {
      "name": "--json",
      "description": "Format the results as JSON",
      "aliases": [
        "-j"
      ]
    },
    {
      "name": "--version",
      "description": "Show version information",
      "aliases": [
        "-v"
      ]
    },
    {
      "name": "--help",
      "description": "Show help and usage information",
      "aliases": [
        "-h"
      ]
    }
  ],
  "arguments": [
    {
      "name": "PATTERN",
      "description": "Glob pattern [default: **/*.dll]",
      "required": true,
      "type": "String",
      "arity": {
        "minimum": 1,
        "maximum": 1
      }
    }
  ]
}