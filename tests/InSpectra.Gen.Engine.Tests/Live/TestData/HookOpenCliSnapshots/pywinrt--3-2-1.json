          "arity": {
            "minimum": 0,
            "maximum": 1
          }
        }
      ]
    },
    {
      "name": "--version",
      "description": "Show version information",
      "arguments": [
        {
          "name": "VERSION",
          "type": "Boolean",
          "arity": {
            "minimum": 0,
            "maximum": 0
          }
        }
      ]
    },
    {
      "name": "-h",
      "description": "Show help and usage information",
      "aliases": [
        "/h",
        "--help",
        "-?",
        "/?"
