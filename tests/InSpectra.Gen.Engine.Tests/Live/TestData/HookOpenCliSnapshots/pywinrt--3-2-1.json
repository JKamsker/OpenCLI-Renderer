{
  "info": {
    "title": "PyWinRT",
    "version": "3.2.1",
    "description": "Py/WinRT is a tool for generating a Python projection of any Windows Runtime library."
  },
  "options": [
    {
      "name": "--input",
      "description": "Windows metadata to include in projection",
      "arguments": [
        {
          "name": "INPUT",
          "type": "ValueTuple\u00602[]",
          "arity": {
            "minimum": 0,
            "maximum": 100000
          }
        }
      ]
    },
    {
      "name": "--reference",
      "description": "Windows metadata to reference from projection",
      "arguments": [
        {
          "name": "REFERENCE",
          "type": "ValueTuple\u00602[]",
          "arity": {
            "minimum": 0,
            "maximum": 100000
          }
        }
      ]
    },
    {
      "name": "--output",
      "description": "Location of generated projection",
      "arguments": [
        {
          "name": "OUTPUT",
          "type": "DirectoryInfo",
          "arity": {
            "minimum": 0,
            "maximum": 1
          }
        }
      ]
    },
    {
      "name": "--include",
      "description": "One or more prefixes to include in projection",
      "arguments": [
        {
          "name": "INCLUDE",
          "type": "String[]",
          "arity": {
            "minimum": 0,
            "maximum": 100000
          }
        }
      ]
    },
    {
      "name": "--exclude",
      "description": "One or more prefixes to exclude from projection",
      "arguments": [
        {
          "name": "EXCLUDE",
          "type": "String[]",
          "arity": {
            "minimum": 0,
            "maximum": 100000
          }
        }
      ]
    },
    {
      "name": "--header-path",
      "description": "Install headers in custom path",
      "arguments": [
        {
          "name": "HEADER_PATH",
          "type": "DirectoryInfo",
          "arity": {
            "minimum": 0,
            "maximum": 1
          }
        }
      ]
    },
    {
      "name": "--nullability-json",
      "description": "Nullability information JSON file",
      "arguments": [
        {
          "name": "NULLABILITY_JSON",
          "type": "FileInfo",
          "arity": {
            "minimum": 0,
            "maximum": 1
          }
        }
      ]
    },
    {
      "name": "--component-dlls",
      "description": "Set this flag when generating projection for user components that will ship with the required .dlls in the Python package",
      "arguments": [
        {
          "name": "COMPONENT_DLLS",
          "type": "Boolean",
          "arity": {
            "minimum": 0,
            "maximum": 1
