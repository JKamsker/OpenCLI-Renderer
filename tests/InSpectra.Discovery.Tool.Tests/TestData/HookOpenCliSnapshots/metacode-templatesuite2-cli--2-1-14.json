{
  "info": {
    "title": "mcts2",
    "version": "2.1.14",
    "description": "Template Suite 2 code generators."
  },
  "commands": [
    {
      "name": "g2c",
      "description": "Generates source code using the named generator and supplied metadata.",
      "options": [
        {
          "name": "--generator",
          "description": "The id of the generator: Freezables,Immutables,Interfaces,MsgPack,JsonPoco,ProtobufNet3,GProto3_Proto,GProto3_CS",
          "aliases": [
            "-g"
          ],
          "arguments": [
            {
              "name": "GENERATOR_ID",
              "required": true,
              "type": "String",
              "arity": {
                "minimum": 1,
                "maximum": 1
              }
            }
          ]
        },
        {
          "name": "--json-metadata",
          "description": "The metadata file (JSON) to process.",
          "aliases": [
            "-jm"
          ],
          "arguments": [
            {
              "name": "METADATA_FILENAME",
              "required": true,
              "type": "String",
              "arity": {
                "minimum": 1,
                "maximum": 1
              }
            }
          ]
        },
        {
          "name": "--assm-metadata",
          "description": "The metadata file (DLL) to process.",
          "aliases": [
            "-am"
          ],
          "arguments": [
            {
              "name": "METADATA_FILENAME",
              "required": true,
              "type": "String",
              "arity": {
                "minimum": 1,
                "maximum": 1
              }
            }
          ]
        },
        {
          "name": "--assm-namespace",
          "description": "The namespace within the assembly to search.",
          "aliases": [
            "-an"
          ],
          "arguments": [
            {
              "name": "ASSEMBLY_NAMESPACE",
              "required": true,
              "type": "String",
              "arity": {
                "minimum": 1,
                "maximum": 1
              }
            }
          ]
        },
        {
          "name": "--output",
          "description": "The implementation file to create.",
          "aliases": [
            "-o"
          ],
          "arguments": [
            {
              "name": "OUTPUT_FILENAME",
              "required": true,
              "type": "String",
              "arity": {
                "minimum": 1,
                "maximum": 1
              }
            }
          ]
        },
        {
          "name": "--output-namespace",
          "description": "The target namespace for the output.",
          "aliases": [
            "-on"
          ],
          "arguments": [
            {
              "name": "OUTPUT_NAMESPACE",
              "required": true,
              "type": "String",
              "arity": {
                "minimum": 1,
                "maximum": 1
              }
            }
          ]
        },
        {
          "name": "--copyright",
          "description": "The copyright notice for the metadata (model) owner",
          "aliases": [
            "-c"
          ],
          "arguments": [
            {
              "name": "COPYRIGHT_NOTICE",
              "required": true,
              "type": "String",
              "arity": {
                "minimum": 1,
                "maximum": 1
              }
            }
          ]
        },
        {
          "name": "--help",
          "description": "Show help and usage information",
          "aliases": [
            "-h"
          ],
          "arguments": [
            {
              "name": "HELP",
              "type": "Boolean",
              "arity": {
                "minimum": 0,
                "maximum": 0
              }
            }
          ]
        }
      ]
    }
  ]
}