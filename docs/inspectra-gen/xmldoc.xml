<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--RENDER-->
  <Command Name="render" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Render documentation from OpenCLI exports.</Description>
    <!--FILE-->
    <Command Name="file" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <Description>Render docs from saved OpenCLI export files.</Description>
      <!--MARKDOWN-->
      <Command Name="markdown" IsBranch="false" 
ClrType="InSpectra.Gen.Commands.Render.FileMarkdownCommand" 
Settings="InSpectra.Gen.Commands.Render.FileRenderSettings">
        <Description>Render Markdown from an OpenCLI JSON file and optional XML 
enrichment file.</Description>
        <Parameters>
          <Argument Name="OPENCLI_JSON" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
            <Description>Path to the OpenCLI JSON export file to 
render.</Description>
          </Argument>
          <Option Short="" Long="command-prefix" Value="TEXT" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Override the CLI command prefix used in rendered 
Markdown examples.</Description>
          </Option>
          <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Preview the resolved render plan without writing 
files.</Description>
          </Option>
          <Option Short="" Long="include-hidden" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Include commands and options marked hidden by the 
source CLI.</Description>
          </Option>
          <Option Short="" Long="include-metadata" Value="NULL" Required="false"
Kind="flag" ClrType="System.Boolean">
            <Description>Include metadata sections in the rendered Markdown or 
HTML output.</Description>
          </Option>
          <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
            <Description>Emit the stable machine-readable JSON envelope instead 
of human output.</Description>
          </Option>
          <Option Short="" Long="layout" Value="LAYOUT" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Markdown layout mode. Supported values are single, 
tree, and hybrid.</Description>
          </Option>
          <Option Short="" Long="no-color" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Disable ANSI color sequences in human-readable console 
output.</Description>
          </Option>
          <Option Short="" Long="out" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Single Markdown file to write when using the single 
layout.</Description>
          </Option>
          <Option Short="" Long="out-dir" Value="DIR" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Output directory to write when using the tree or hybrid
layout.</Description>
          </Option>
          <Option Short="" Long="output" Value="MODE" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Override the output mode. Supported values are human 
and json.</Description>
          </Option>
          <Option Short="" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Allow existing output files or directories to be 
replaced.</Description>
          </Option>
          <Option Short="q" Long="quiet" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Suppress non-essential console output.</Description>
          </Option>
          <Option Short="" Long="split-depth" Value="DEPTH" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
            <Description>Depth at which hybrid layout emits one file per command
group (defaults to 1).</Description>
          </Option>
          <Option Short="" Long="title" Value="TEXT" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Override the CLI title shown in Markdown headings and 
overview text.</Description>
          </Option>
          <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Increase diagnostic detail in the rendered summary 
output.</Description>
          </Option>
          <Option Short="" Long="xmldoc" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Optional XML documentation file used to enrich missing 
descriptions.</Description>
          </Option>
        </Parameters>
      </Command>
      <!--HTML-->
      <Command Name="html" IsBranch="false" 
ClrType="InSpectra.Gen.Commands.Render.FileHtmlCommand" 
Settings="InSpectra.Gen.Commands.Render.FileHtmlSettings">
        <Description>Render an HTML app bundle from an OpenCLI JSON file and 
optional XML enrichment file.</Description>
        <Parameters>
          <Argument Name="OPENCLI_JSON" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
            <Description>Path to the OpenCLI JSON export file to 
render.</Description>
          </Argument>
          <Option Short="" Long="accent" Value="COLOR" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Custom accent color for light mode (hex, e.g. 
"#7c3aed").</Description>
          </Option>
          <Option Short="" Long="accent-dark" Value="COLOR" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Custom accent color for dark mode (hex). Falls back to 
--accent if omitted.</Description>
          </Option>
          <Option Short="" Long="color-theme" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Set the color theme (cyan, indigo, emerald, amber, 
rose, blue).</Description>
          </Option>
          <Option Short="" Long="command-prefix" Value="TEXT" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Override the CLI command prefix used in generated 
examples and the composer.</Description>
          </Option>
          <Option Short="" Long="compression-level" Value="LEVEL" 
Required="false" Kind="scalar" ClrType="System.Nullable`1[[System.Int32, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
            <Description>Compression level: 0 = none, 1 = compress embedded 
JSON, 2 = self-extracting bundle (default 2).</Description>
          </Option>
          <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Preview the resolved render plan without writing 
files.</Description>
          </Option>
          <Option Short="" Long="enable-nuget-browser" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
            <Description>Enable the NuGet package browser on the viewer home 
screen.</Description>
          </Option>
          <Option Short="" Long="enable-package-upload" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
            <Description>Enable local package upload on the viewer home 
screen.</Description>
          </Option>
          <Option Short="" Long="enable-url" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Allow the viewer to load OpenCLI inputs from URL query 
parameters.</Description>
          </Option>
          <Option Short="" Long="include-hidden" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Include commands and options marked hidden by the 
source CLI.</Description>
          </Option>
          <Option Short="" Long="include-metadata" Value="NULL" Required="false"
Kind="flag" ClrType="System.Boolean">
            <Description>Include metadata sections in the rendered Markdown or 
HTML output.</Description>
          </Option>
          <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
            <Description>Emit the stable machine-readable JSON envelope instead 
of human output.</Description>
          </Option>
          <Option Short="" Long="label" Value="TEXT" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Custom label shown in the viewer header (e.g. a version
string).</Description>
          </Option>
          <Option Short="" Long="no-color" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Disable ANSI color sequences in human-readable console 
output.</Description>
          </Option>
          <Option Short="" Long="no-composer" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Hide the interactive command composer from the 
generated HTML app.</Description>
          </Option>
          <Option Short="" Long="no-dark" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Disable dark mode in the generated HTML 
app.</Description>
          </Option>
          <Option Short="" Long="no-light" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Disable light mode in the generated HTML 
app.</Description>
          </Option>
          <Option Short="" Long="no-theme-picker" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Hide the color theme picker from the viewer 
toolbar.</Description>
          </Option>
          <Option Short="" Long="out-dir" Value="DIR" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Directory where the HTML app bundle should be 
written.</Description>
          </Option>
          <Option Short="" Long="output" Value="MODE" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Override the output mode. Supported values are human 
and json.</Description>
          </Option>
          <Option Short="" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Allow existing output files or directories to be 
replaced.</Description>
          </Option>
          <Option Short="q" Long="quiet" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Suppress non-essential console output.</Description>
          </Option>
          <Option Short="" Long="show-home" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Show the viewer home screen button in the generated 
HTML app.</Description>
          </Option>
          <Option Short="" Long="single-file" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Emit a single self-contained HTML file with all assets 
inlined. Works from file:// without a web server.</Description>
          </Option>
          <Option Short="" Long="theme" Value="MODE" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Set the initial theme mode (light or 
dark).</Description>
          </Option>
          <Option Short="" Long="title" Value="TEXT" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Override the CLI title shown in the viewer header and 
overview.</Description>
          </Option>
          <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Increase diagnostic detail in the rendered summary 
output.</Description>
          </Option>
          <Option Short="" Long="xmldoc" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Optional XML documentation file used to enrich missing 
descriptions.</Description>
          </Option>
        </Parameters>
      </Command>
    </Command>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Generate raw OpenCLI JSON from a package, executable, or .NET 
project.</Description>
    <!--PACKAGE-->
    <Command Name="package" IsBranch="false" 
ClrType="InSpectra.Gen.Commands.Generate.PackageGenerateCommand" 
Settings="InSpectra.Gen.Commands.Generate.PackageGenerateSettings">
      <Description>Generate opencli.json by installing and analyzing a .NET tool
package.</Description>
      <Parameters>
        <Argument Name="PACKAGE_ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>NuGet package id for the .NET tool package to 
analyze.</Description>
        </Argument>
        <Option Short="" Long="cli-framework" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Hint or override the detected CLI framework for 
non-native analysis.</Description>
        </Option>
        <Option Short="" Long="command" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Override the root command name used for generated OpenCLI
documents.</Description>
        </Option>
        <Option Short="" Long="crawl-out" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Write crawl.json when the selected acquisition mode 
produces crawl data.</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Emit the stable machine-readable JSON envelope instead of
human output.</Description>
        </Option>
        <Option Short="" Long="no-color" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Disable ANSI color sequences in human-readable console 
output.</Description>
        </Option>
        <Option Short="" Long="opencli-arg" Value="ARG" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Override the arguments used to invoke the installed 
tool's OpenCLI export command.</Description>
        </Option>
        <Option Short="" Long="opencli-mode" Value="MODE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>OpenCLI acquisition mode: native, auto, help, clifx, 
static, or hook.</Description>
        </Option>
        <Option Short="" Long="out" Value="FILE" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Write the generated OpenCLI JSON to this file instead of 
stdout.</Description>
        </Option>
        <Option Short="" Long="output" Value="MODE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Override the output mode. Supported values are human and 
json.</Description>
        </Option>
        <Option Short="q" Long="quiet" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Suppress non-essential console output.</Description>
        </Option>
        <Option Short="" Long="timeout" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Timeout in seconds for package install and command 
execution.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Increase diagnostic detail in machine-readable 
failures.</Description>
        </Option>
        <Option Short="" Long="version" Value="VERSION" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Package version to install and analyze.</Description>
        </Option>
        <Option Short="" Long="with-xmldoc" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Enrich the generated OpenCLI document with XML 
documentation when the source CLI exposes it.</Description>
        </Option>
        <Option Short="" Long="xmldoc-arg" Value="ARG" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Override the arguments used to invoke the source CLI's 
XML documentation export command.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--EXEC-->
    <Command Name="exec" IsBranch="false" 
ClrType="InSpectra.Gen.Commands.Generate.ExecGenerateCommand" 
Settings="InSpectra.Gen.Commands.Generate.ExecGenerateSettings">
      <Description>Generate opencli.json from a local executable or 
script.</Description>
      <Parameters>
        <Argument Name="SOURCE" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>CLI executable or script to invoke.</Description>
        </Argument>
        <Option Short="" Long="cli-framework" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Hint or override the detected CLI framework for 
non-native analysis.</Description>
        </Option>
        <Option Short="" Long="command" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Override the root command name used for generated OpenCLI
documents.</Description>
        </Option>
        <Option Short="" Long="crawl-out" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Write crawl.json when the selected acquisition mode 
produces crawl data.</Description>
        </Option>
        <Option Short="" Long="cwd" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Working directory to use when invoking the source 
CLI.</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Emit the stable machine-readable JSON envelope instead of
human output.</Description>
        </Option>
        <Option Short="" Long="no-color" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Disable ANSI color sequences in human-readable console 
output.</Description>
        </Option>
        <Option Short="" Long="opencli-arg" Value="ARG" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Override the arguments used to invoke the source CLI's 
OpenCLI export command.</Description>
        </Option>
        <Option Short="" Long="opencli-mode" Value="MODE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>OpenCLI acquisition mode: native, auto, help, clifx, 
static, or hook.</Description>
        </Option>
        <Option Short="" Long="out" Value="FILE" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Write the generated OpenCLI JSON to this file instead of 
stdout.</Description>
        </Option>
        <Option Short="" Long="output" Value="MODE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Override the output mode. Supported values are human and 
json.</Description>
        </Option>
        <Option Short="q" Long="quiet" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Suppress non-essential console output.</Description>
        </Option>
        <Option Short="" Long="source-arg" Value="ARG" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Additional arguments passed directly to the source 
executable before the export command.</Description>
        </Option>
        <Option Short="" Long="timeout" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Timeout in seconds for source execution.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Increase diagnostic detail in machine-readable 
failures.</Description>
        </Option>
        <Option Short="" Long="with-xmldoc" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Enrich the generated OpenCLI document with XML 
documentation when the source CLI exposes it.</Description>
        </Option>
        <Option Short="" Long="xmldoc-arg" Value="ARG" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Override the arguments used to invoke the source CLI's 
XML documentation export command.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--DOTNET-->
    <Command Name="dotnet" IsBranch="false" 
ClrType="InSpectra.Gen.Commands.Generate.DotnetGenerateCommand" 
Settings="InSpectra.Gen.Commands.Generate.DotnetGenerateSettings">
      <Description>Generate opencli.json from a .NET project.</Description>
      <Parameters>
        <Argument Name="PROJECT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path to a .NET project file (.csproj/.fsproj/.vbproj) or 
a directory containing one.</Description>
        </Argument>
        <Option Short="" Long="cli-framework" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Hint or override the detected CLI framework for 
non-native analysis.</Description>
        </Option>
        <Option Short="" Long="command" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Override the root command name used for generated OpenCLI
documents.</Description>
        </Option>
        <Option Short="c" Long="configuration" Value="CONFIG" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Build configuration passed to dotnet run/build (e.g. 
Release).</Description>
        </Option>
        <Option Short="" Long="crawl-out" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Write crawl.json when the selected acquisition mode 
produces crawl data.</Description>
        </Option>
        <Option Short="" Long="cwd" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Working directory used when invoking 
dotnet.</Description>
        </Option>
        <Option Short="f" Long="framework" Value="TFM" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Target framework moniker passed to dotnet run/build (e.g.
net10.0).</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Emit the stable machine-readable JSON envelope instead of
human output.</Description>
        </Option>
        <Option Short="" Long="launch-profile" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Launch profile to use for dotnet run native 
mode.</Description>
        </Option>
        <Option Short="" Long="no-build" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Skip the implicit build step for dotnet 
run/build.</Description>
        </Option>
        <Option Short="" Long="no-color" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Disable ANSI color sequences in human-readable console 
output.</Description>
        </Option>
        <Option Short="" Long="no-restore" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Skip the implicit restore step for dotnet 
run/build.</Description>
        </Option>
        <Option Short="" Long="opencli-arg" Value="ARG" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Override the arguments used to invoke the project's 
OpenCLI export command.</Description>
        </Option>
        <Option Short="" Long="opencli-mode" Value="MODE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>OpenCLI acquisition mode: native, auto, help, clifx, 
static, or hook.</Description>
        </Option>
        <Option Short="" Long="out" Value="FILE" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Write the generated OpenCLI JSON to this file instead of 
stdout.</Description>
        </Option>
        <Option Short="" Long="output" Value="MODE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Override the output mode. Supported values are human and 
json.</Description>
        </Option>
        <Option Short="q" Long="quiet" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Suppress non-essential console output.</Description>
        </Option>
        <Option Short="" Long="timeout" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Timeout in seconds for dotnet execution.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Increase diagnostic detail in machine-readable 
failures.</Description>
        </Option>
        <Option Short="" Long="with-xmldoc" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Enrich the generated OpenCLI document with XML 
documentation when the source CLI exposes it.</Description>
        </Option>
        <Option Short="" Long="xmldoc-arg" Value="ARG" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Override the arguments used to invoke the source CLI's 
XML documentation export command.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>
